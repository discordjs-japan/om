{
  "name": "om",
  "version": "0.7.0",
  "description": "TTS Bot for Discord.js Japan User Group",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --import=tsx --env-file=.env src/main.ts",
    "build": "node scripts/build.js",
    "start": "node dist/main.js",
    "check": "run-s -c *:check",
    "fix": "run-s -c *:fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "type:check": "tsc -p tsconfig.json -p jsconfig.json",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "node .husky/install.mjs",
    "test": "node --import=tsx --test --watch src/**/*.test.ts",
    "test:ci": "node --import=tsx --test src/**/*.test.ts"
  },
  "author": "Discord.js Japan User Group (discordjs-japan.org)",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.3",
    "@types/punycode": "2.1.4",
    "esbuild": "0.28.1",
    "esbuild-plugin-version-injector": "1.2.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import-x": "4.17.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  },
  "dependencies": {
    "@discordjs-japan/om-syrinx": "github:discordjs-japan/om-syrinx#v0.5.3",
    "@discordjs/voice": "0.19.2",
    "@snazzah/davey": "0.1.12",
    "discord-markdown-parser": "1.3.1",
    "discord.js": "14.26.5",
    "pino": "10.3.1",
    "simple-markdown": "0.7.3"
  },
  "allowScripts": {
    "github:discordjs-japan/om-syrinx#e6932946f173b9fb41def87b734d8577e024cb00": true,
    "esbuild@0.28.1": true,
    "unrs-resolver@1.11.1": true
  }
}
